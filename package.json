{
  "name": "@ckomop0x/weather-cli",
  "private": false,
  "version": "2.0.1",
  "description": "CLI for getting weather",
  "main": "dist/weather.js",
  "bin": {
    "weather": "dist/weather.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "start": "tsx weather.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"./**/*.{ts,tsx}\" --fix",
    "lint:check": "eslint \"./**/*.{ts,tsx}\"",
    "check-ts": "tsc --noEmit",
    "check-style": "prettier --check .",
    "format": "prettier . --write",
    "release": "pnpm build && pnpm publish --access public"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier . --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "keywords": [
    "cli",
    "weather"
  ],
  "author": "Pavel Klochkov",
  "license": "ISC",
  "homepage": "https://github.com/ckomop0x/weather-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ckomop0x/weather-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ckomop0x/weather-cli/issues",
    "email": "pail.klochkov@gmail.com"
  },
  "dependencies": {
    "axios": "^1.7.4",
    "chalk": "^5.2.0",
    "dedent-js": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.1",
    "globals": "17.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  }
}
